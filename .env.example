# Copy to .env and edit if you want to override defaults.
# scripts/run.sh sets HOST_PORT itself (8080, or the next free port) - you
# don't normally need to set it here.

# Both scvis-go and dynamic_analysis are public, so the default HTTPS URLs
# work with no auth needed. Use the SSH form (git@github.com:vaccs/...) if
# either ever goes private again - see README.md for ssh-agent forwarding.
SCVIS_REPO_URL=https://github.com/vaccs/scvis-go.git
SCVIS_REPO_REF=main
VACCS_REPO_URL=https://github.com/vaccs/dynamic_analysis.git
VACCS_REPO_REF=master

# Database credentials used inside the scvis container (MySQL runs
# in-container, not exposed to the host).
DB_NAME=scvis
DB_USER=scvis
DB_PASSWD=scvis_dev_password

# GitHub issue-submission integration (internal/github). Leave GITHUB_TOKEN
# blank to disable it.
GITHUB_TOKEN=
GITHUB_OWNER=vaccs
GITHUB_REPO=scvis-go

# Where scvis reaches the VACCS analyzer. Defaults to the compose network
# (vaccs:3580) when both containers run together via scripts/run.sh - leave
# this unset unless you're running vaccs elsewhere (e.g. in a GitHub
# Codespace for real x86_64 hardware on Apple Silicon, see README.md) while
# scvis stays local. In that split setup:
#   docker compose up -d --build --no-deps scvis
# with VACCS_HOST=host.docker.internal here, and a real TCP tunnel from your
# host's VACCS_PORT to the Codespace's vaccs:3580 (not GitHub's normal
# HTTP-only port forwarding - vaccs speaks a raw custom protocol):
#   gh codespace ports forward 3580:3580 -c <codespace-name>
#VACCS_HOST=vaccs
#VACCS_PORT=3580

# Default admin account seeded on first run only (when the users table is empty).
SEED_ADMIN_NAME=admin
SEED_ADMIN_EMAIL=admin@scvis.local
SEED_ADMIN_PASSWORD=admin1234
